# Base URL of the app under test.
# Used by playwright.config.js (as baseURL) and setup/globalSetup.js (for direct goto calls).
BASE_URL=https://rahulshettyacademy.com/client/

# Existing, stable test account used by tests/auth/login.spec.js.
# This flow tests login behaviour against an account that already exists —
# unlike the per-worker accounts registered fresh by globalSetup.js.
LOGIN_USERNAME=
LOGIN_PASSWORD=

# Primary account for API-level security and mock tests.
# Used by tests/security/authorization-bypass.spec.js and
# tests/shopping/mocked-orders-response.spec.js to obtain an auth token
# via the login API endpoint.
SECURITY_TEST_EMAIL=
SECURITY_TEST_PASSWORD=

# Secondary (separate) account used exclusively by
# tests/security/authorization-bypass.spec.js.
# Its orders are used as the "foreign" orders that the primary account
# should NOT be able to view — must be a genuinely different account
# from SECURITY_TEST_EMAIL.
SECONDARY_ACCOUNT_EMAIL=
SECONDARY_ACCOUNT_PASSWORD=
